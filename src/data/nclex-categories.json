{
  "model": "NCLEX-NG Clinical Judgment Measurement Model (CJMM)",
  "description": "The Next Generation NCLEX (NCLEX-NG) emphasizes clinical judgment using a six-layer measurement model.",
  "clinicalJudgmentLayers": [
    {
      "id": "RC",
      "layer": "Recognize Cues",
      "description": "Identify relevant information from many sources (e.g., medical history, vital signs) about the client's current condition.",
      "examples": [
        "Identify significant changes in vital signs.",
        "Recognize abnormal laboratory findings.",
        "Identify relevant data from a health history."
      ]
    },
    {
      "id": "AC",
      "layer": "Analyze Cues",
      "description": "Connect recognized cues to the client's clinical presentation and determine what the cues mean.",
      "examples": [
        "Connect assessment findings to pathophysiology.",
        "Analyze patterns in patient data to identify trends.",
        "Distinguish between expected and unexpected findings."
      ]
    },
    {
      "id": "PH",
      "layer": "Prioritize Hypotheses",
      "description": "Evaluate and prioritize hypotheses (explanations) for the client's condition to determine the most likely explanation.",
      "examples": [
        "Rank possible client conditions by urgency.",
        "Weigh evidence to determine the most probable clinical explanation.",
        "Determine which potential problems pose the greatest risk."
      ]
    },
    {
      "id": "GS",
      "layer": "Generate Solutions",
      "description": "Identify expected outcomes and use clinical judgment to determine possible interventions to address client needs.",
      "examples": [
        "Identify interventions to address urgent clinical needs.",
        "Generate a list of appropriate nursing actions.",
        "Determine which outcomes are realistic given the clinical context."
      ]
    },
    {
      "id": "TA",
      "layer": "Take Action",
      "description": "Implement the solution with the highest priority that addresses the client need.",
      "examples": [
        "Perform the priority nursing intervention.",
        "Administer medications safely.",
        "Implement evidence-based protocols."
      ]
    },
    {
      "id": "EO",
      "layer": "Evaluate Outcomes",
      "description": "Evaluate the outcomes of the interventions to determine if the expected outcomes were achieved.",
      "examples": [
        "Compare client response to expected outcomes.",
        "Determine whether goals were met.",
        "Revise the plan of care based on evaluation findings."
      ]
    }
  ],
