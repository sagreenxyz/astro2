---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InfectionControlApp from '../../components/infection-control/InfectionControlApp.svelte';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Infection Control Challenge"
  description="Master isolation precautions and chain-of-infection interventions through gamified clinical case simulations."
  fullWidth={true}
>
  <div class="max-w-4xl mx-auto px-4 pt-3 pb-1 flex justify-end">
    <a
      href={`${base}infection-control/cases/`}
      class="btn btn-ghost btn-sm font-sans gap-1 opacity-70 hover:opacity-100"
    >
      📋 Case Synopses
    </a>
  </div>
  <InfectionControlApp client:load />
</BaseLayout>
