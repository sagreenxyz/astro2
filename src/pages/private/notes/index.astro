---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

// Only include private/protected notes that are not drafts.
// The auth gate below (client-side session check) prevents unauthenticated access.
const allNotes = await getCollection(
  'notes',
  ({ data }) => !data.draft && (data.visibility === 'private' || data.visibility === 'protected')
);
allNotes.sort((a, b) => b.data.createdAt.getTime() - a.data.createdAt.getTime());

// Collect all unique tags for filtering
const allTags = [...new Set(allNotes.flatMap((n) => n.data.tags))].sort();

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Private Notes" description="Private and protected note hub">
  <div id="private-notes-content" hidden>
    <div class="flex items-start justify-between flex-wrap gap-4 mb-6">
      <div>
        <h1 class="text-3xl font-bold mb-1">Private Notes</h1>
        <p class="text-base-content/60 font-sans">
          Protected notes visible only to authenticated users.
        </p>
      </div>
      <a href={`${base}private/`} class="btn btn-ghost btn-sm font-sans">← Private Area</a>
    </div>

    {/* Review needed banner */}
    {
      allNotes.some((n) => n.data.needsReview) && (
        <div class="alert alert-warning mb-6 font-sans" role="alert">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5 shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"
            />
          </svg>
          <span>
            {allNotes.filter((n) => n.data.needsReview).length} note(s) flagged for review. Check
            them before promoting to public.
          </span>
        </div>
      )
    }

    {/* Duplicate detection banner */}
    {
      allNotes.some((n) => n.data.duplicateOf) && (
        <div class="alert alert-error mb-6 font-sans" role="alert">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5 shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"
            />
          </svg>
          <span>
            {allNotes.filter((n) => n.data.duplicateOf).length} note(s) flagged as possible
            duplicates. Review and merge or discard before publishing.
          </span>
        </div>
      )
    }

    {/* Tag filter (client-side) */}
    {
      allTags.length > 0 && (
        <div class="mb-6">
          <p class="text-xs font-semibold uppercase tracking-wide text-base-content/50 mb-2 font-sans">
            Filter by tag
          </p>
          <div class="flex flex-wrap gap-2">
            <button
              class="badge badge-outline badge-sm font-sans cursor-pointer tag-filter active"
              data-tag="__all__"
            >
              All
            </button>
            {allTags.map((tag) => (
              <button
                class="badge badge-outline badge-sm font-sans cursor-pointer tag-filter"
                data-tag={tag}
              >
                {tag}
              </button>
            ))}
          </div>
        </div>
      )
    }

    {
      allNotes.length === 0 ? (
        <div class="alert font-sans">
          <span>
            No private notes yet. Set <code>visibility: private</code> or{' '}
            <code>visibility: protected</code> in a note's frontmatter.
          </span>
        </div>
      ) : (
        <ul class="space-y-4" id="notes-list">
          {allNotes.map((entry) => (
            <li data-tags={JSON.stringify(entry.data.tags)}>
              <div class="card card-border bg-base-100 font-sans">
                <div class="card-body py-4">
                  <div class="flex items-start justify-between gap-2 flex-wrap">
                    <h2 class="card-title text-base">{entry.data.title}</h2>
                    <div class="flex gap-1 flex-wrap">
                      <span
                        class={`badge badge-sm ${entry.data.visibility === 'protected' ? 'badge-error' : 'badge-warning'}`}
                      >
                        🔒 {entry.data.visibility}
                      </span>
                      {entry.data.needsReview && (
                        <span class="badge badge-warning badge-sm">needs review</span>
                      )}
                      {entry.data.duplicateOf && (
                        <span class="badge badge-error badge-sm">possible duplicate</span>
                      )}
                      {entry.data.noteType !== 'general' && (
                        <span class="badge badge-ghost badge-sm">{entry.data.noteType}</span>
                      )}
                    </div>
                  </div>

                  <time
                    datetime={entry.data.createdAt.toISOString()}
                    class="text-xs text-base-content/40 mt-1"
                  >
                    {entry.data.createdAt.toLocaleDateString()}
                  </time>

                  {entry.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1 mt-2">
                      {entry.data.tags.map((tag) => (
                        <span class="badge badge-outline badge-sm">{tag}</span>
                      ))}
                    </div>
                  )}

                  {entry.data.needsReview && entry.data.reviewReason && (
                    <p class="text-sm text-warning mt-2">⚠ {entry.data.reviewReason}</p>
                  )}

                  {entry.data.duplicateOf && (
                    <p class="text-sm text-error mt-2">
                      Possible duplicate of: <code>{entry.data.duplicateOf}</code>
                    </p>
                  )}

                  {(entry.data.sourceIssue || entry.data.sourceUrl) && (
                    <div class="mt-2 text-xs text-base-content/50 space-y-0.5">
                      {entry.data.sourceIssue && (
                        <p>
                          Source issue:{' '}
                          <a
                            href={entry.data.sourceIssue}
                            class="link link-primary"
                            target="_blank"
                            rel="noopener"
                          >
                            {entry.data.sourceIssue}
                          </a>
                        </p>
                      )}
                      {entry.data.sourceUrl && (
                        <p>
                          Source:{' '}
                          <a
                            href={entry.data.sourceUrl}
                            class="link link-primary"
                            target="_blank"
                            rel="noopener"
                          >
                            {entry.data.sourceUrl}
                          </a>
                        </p>
                      )}
                    </div>
                  )}
                </div>
              </div>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</BaseLayout>

<script define:vars={{ base }}>
  const SESSION_KEY = 'lms_auth';
  const REDIRECT_KEY = 'lms_redirect';

  const content = document.getElementById('private-notes-content');

  if (sessionStorage.getItem(SESSION_KEY) === 'ok') {
    if (content) content.hidden = false;
  } else {
    sessionStorage.setItem(
      REDIRECT_KEY,
      window.location.pathname + window.location.search + window.location.hash
    );
    window.location.replace(base + 'login/');
  }

  // Client-side tag filtering
  const filterBtns = document.querySelectorAll('.tag-filter');
  const noteItems = document.querySelectorAll('#notes-list > li');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.getAttribute('data-tag');

      filterBtns.forEach((b) => b.classList.remove('active', 'badge-primary'));
      btn.classList.add('active', 'badge-primary');

      noteItems.forEach((item) => {
        if (tag === '__all__') {
          item.style.display = '';
        } else {
          const tags = JSON.parse(item.getAttribute('data-tags') || '[]');
          item.style.display = tags.includes(tag) ? '' : 'none';
        }
      });
    });
  });
</script>
